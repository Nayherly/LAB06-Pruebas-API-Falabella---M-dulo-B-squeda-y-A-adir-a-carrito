    {
      "name": "Módulo Búsqueda",
      "item": [
        {
          "name": "TC-007: Búsqueda exitosa por texto exacto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC-007: Status 200 - búsqueda exitosa\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-007: Retorna array de productos\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.be.an(\"array\");\r",
                  "    pm.expect(json.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-007: Productos pertenecen a la categoría buscada\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    json.forEach(function(product) {\r",
                  "        pm.expect(product.category).to.equal(\"electronics\");\r",
                  "    });\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://fakestoreapi.com/products/category/electronics",
              "protocol": "https",
              "host": [
                "fakestoreapi",
                "com"
              ],
              "path": [
                "products",
                "category",
                "electronics"
              ]
            }
          },
          "response": []
        },
