          "name": "TC-011: Agregar producto al carrito",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC-011: Status 201 - producto agregado al carrito\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-011: Respuesta contiene ID del carrito\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"id\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC-011: Carrito contiene el producto agregado\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.products[0].productId).to.equal(5);\r",
                  "    pm.expect(json.products[0].quantity).to.equal(1);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
